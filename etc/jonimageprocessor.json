{
  "camera": {
    "device": "/dev/video0",
    "format": "MJPG",
    "connectTimeoutSeconds": 10
  },
  "processing": {
    "size": "1280x720"
  },
  "segmentation": {
    "size": "384x384",
    "maskModel": "models/modnet_photographic_portrait_matting.onnx",
    "threshold": 0.5,
    "smoothing": 0.65,
    "morphology": "light"
  },
  "background": {
    "effect": "color",
    "overlayColor": "0,255,0",
    "overlayAlpha": 1.0
  },
  "output": {
    "size": "auto"
  },
  "ipc": {
    "socket": "/tmp/jonimageprocessor.sock"
  },
  "display": {
    "backend": "drm",
    "mode": "fullscreen"
  },
  "diagnostics": {
    "benchmark": false
  }
}
